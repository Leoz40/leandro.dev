{
  "name": "portifolio",
  "version": "1.0.0",
  "description": "Portfolio pessoal profissional",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:css": "npx tailwindcss -i ./public/css/tailwind.src.css -o ./public/css/tailwind.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/tailwind.src.css -o ./public/css/tailwind.css --watch",
    "build": "npm run build:css && node server.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
